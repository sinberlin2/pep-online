# COPY this file to .env and add real keys there — NEVER put secrets in .env.example (it is committed to GitHub).

# Optional: use remove.bg API instead of local rembg (often cleaner edges)
# REMOVEBG_API_KEY=your_key_here

# rembg model: isnet-general-use (default), u2net, silueta, etc.
# REMBG_MODEL=isnet-general-use

# --- Site design agents (OpenAI / ChatGPT API — default) ---
LAYOUT_AGENT_PROVIDER=openai
OPENAI_API_KEY=your_openai_key_here
CONCEPT_AGENT_MODEL=gpt-4.1
REVIEW_AGENT_MODEL=gpt-4o
LAYOUT_AGENT_MODEL=gpt-4o-mini
# Concept agent: search web for similar drink sites (default on when CLI exists)
# CONCEPT_AGENT_WEB_SEARCH=1

# --- Hero composition agent (compose can/glass/garnish + vision review loop) ---
# Provider for BOTH hero agents: openai or anthropic
HERO_PROVIDER=openai
# Optional model overrides. Leave unset to use sensible per-provider defaults:
#   openai    -> compose gpt-4.1,          review gpt-4o
#   anthropic -> compose claude-sonnet-4-6, review claude-sonnet-4-6
# HERO_COMPOSE_MODEL=
# HERO_REVIEW_MODEL=
# Max compose -> render -> review iterations before stopping
# HERO_MAX_ITERATIONS=4
# Minimum overall review score (0-100) required to auto-approve
# HERO_PASS_SCORE=82

# --- Anthropic (Claude) — needed only when HERO_PROVIDER=anthropic ---
# ANTHROPIC_API_KEY=your_anthropic_key_here

# Optional later: ANTHROPIC_API_KEY=
