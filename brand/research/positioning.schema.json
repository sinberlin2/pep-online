{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PEP positioning",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "brand",
    "oneLiner",
    "positioningStatement",
    "audience",
    "occasions",
    "personalityAdjectives",
    "voice",
    "visual",
    "inLineBrands",
    "antiReferences",
    "layoutOnlyReferences",
    "brandFitRules"
  ],
  "properties": {
    "version": { "type": "integer" },
    "brand": { "type": "string" },
    "domain": { "type": "string" },
    "oneLiner": { "type": "string" },
    "positioningStatement": { "type": "string" },
    "audience": { "type": "array", "items": { "type": "string" } },
    "occasions": { "type": "array", "items": { "type": "string" } },
    "personalityAdjectives": { "type": "array", "items": { "type": "string" } },
    "voice": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tone", "tagline", "avoidWords"],
      "properties": {
        "tone": { "type": "string" },
        "tagline": { "type": "string" },
        "avoidWords": { "type": "array", "items": { "type": "string" } }
      }
    },
    "visual": {
      "type": "object",
      "additionalProperties": false,
      "required": ["colorsFromBrandJson", "mood", "photography", "typography", "rejectLooks"],
      "properties": {
        "colorsFromBrandJson": { "type": "boolean" },
        "mood": { "type": "string" },
        "photography": { "type": "string" },
        "typography": { "type": "string" },
        "rejectLooks": { "type": "array", "items": { "type": "string" } }
      }
    },
    "inLineBrands": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "why", "adjectives", "designPatterns"],
        "properties": {
          "name": { "type": "string" },
          "url": { "type": "string" },
          "why": { "type": "string" },
          "adjectives": { "type": "array", "items": { "type": "string" } },
          "designPatterns": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "antiReferences": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "why"],
        "properties": {
          "name": { "type": "string" },
          "url": { "type": "string" },
          "why": { "type": "string" }
        }
      }
    },
    "layoutOnlyReferences": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "patterns"],
        "properties": {
          "name": { "type": "string" },
          "url": { "type": "string" },
          "patterns": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "brandFitRules": { "type": "array", "items": { "type": "string" } }
  }
}
